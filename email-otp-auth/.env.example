# Brevo (Sendinblue) transactional email API
# Get your API key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Verified sender email at https://app.brevo.com/settings/senders
SENDER_EMAIL=

# JWT secret (generate a random string, e.g. openssl rand -hex 32)
JWT_SECRET=

# Server port (default 3000)
PORT=3000
